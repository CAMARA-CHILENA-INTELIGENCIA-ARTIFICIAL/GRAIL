# GRAIL — example environment file.
# Copy to .env and fill in the keys for the providers you actually use.
# All variables are optional. If a provider's key is missing, GRAIL falls back to other
# configured providers or errors clearly when that provider is requested.

# --- LLM providers (chat completions, OpenAI-compatible) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPINFRA_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Local servers (vLLM, llama.cpp, Ollama) — usually no key needed; set the base URL via config.
OLLAMA_API_KEY=
LOCAL_API_KEY=

# --- Embedding provider ---
# Defaults to the same DEEPINFRA_API_KEY for "intfloat/multilingual-e5-large".
EMBEDDING_API_KEY=

# --- Optional: AWS S3 storage backend ---
# Only needed if you install the [s3] extra and configure storage.backend=s3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=
AWS_BUCKET_NAME=
